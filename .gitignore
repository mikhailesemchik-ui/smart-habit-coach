app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Flutter/Dart related (additional)
.flutter-plugins
.packages
.pub-cache/

# Node
node_modules/

# Environment and secrets
.env
.env.*
*.env

# Android release signing (see docs/release_signing.md) — never commit these
*.jks
*.keystore
key.properties
android/key.properties
android/app/key.properties

# Supabase local state
supabase/.temp/

# Build outputs (defense in depth; /build/ above already covers these)
*.apk
*.aab
*.ipa

# OS files
Thumbs.db
